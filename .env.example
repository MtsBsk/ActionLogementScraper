# Departements a surveiller (numeros separes par des virgules)
# 75=Paris, 92=Hauts-de-Seine, 93=Seine-Saint-Denis, 94=Val-de-Marne
# 77=Seine-et-Marne, 78=Yvelines, 91=Essonne, 95=Val-d'Oise
# 69=Rhone, 13=Bouches-du-Rhone, 31=Haute-Garonne, 33=Gironde
# 59=Nord, 67=Bas-Rhin, 44=Loire-Atlantique, 34=Herault
# 06=Alpes-Maritimes, 35=Ille-et-Vilaine
FILTER_DEPARTMENTS=75,92,93,94

# Loyer max charges comprises en EUR (0 = pas de limite)
FILTER_MAX_RENT=800

# Nombre de pieces (0 = pas de limite)
FILTER_MIN_ROOMS=1
FILTER_MAX_ROOMS=3

# Surface minimale en m2 (0 = pas de limite)
FILTER_MIN_SURFACE=20

# Typologie (separes par des virgules, vide = toutes)
# Valeurs possibles : T1, T1BIS, T2, T3, T4, T5
FILTER_TYPOLOGIES=T2,T3

# Configuration email Resend
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_TO=monemail@gmail.com
EMAIL_FROM=onboarding@resend.dev

# Offres reservees entreprise (optionnel - laisser vide pour API publique uniquement)
# Email et mot de passe de votre compte al-in.fr
ALIN_EMAIL=
ALIN_PASSWORD=
# Numero unique de dossier (NUR) visible sur votre espace al-in.fr
ALIN_NUR=
